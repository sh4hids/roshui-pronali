---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<p
  class="relative mb-6 w-full overflow-hidden pb-2 text-lg font-normal text-chilli-600 before:absolute before:bottom-0 before:left-0 before:h-[5px] before:w-16 before:bg-chilli-600 after:absolute after:bottom-0.5 after:left-0 after:h-[1px] after:w-11/12 after:max-w-xs after:bg-chilli-600/50 sm:text-xl"
>
  {title}
</p>
