---
import { Image } from 'astro:assets';

import heroImage from '@/assets/images/spices.svg';
import heroImageDark from '@/assets/images/spices-dark.svg';
---

<Image src={heroImage} alt="hero image" class="h-[500px] w-auto dark:hidden" />
<Image
    src={heroImageDark}
    alt="hero image"
    class="hidden h-[500px] w-auto dark:block"
/>
